{
  "region": "us-east-1",
  "userPoolId": "us-east-1_localDev01",
  "userPoolName": "cognito-local",
  "port": 9229,
  "clients": [
    {
      "clientId": "my-app-local",
      "clientSecret": "local-secret",
      "clientName": "My App",
